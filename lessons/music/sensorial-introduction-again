                    <!-- 13 Tone bars (C to C). Width = 25px each. -->
                    <g stroke="#94A3B8" stroke-width="1">
                        <!-- Unpulled bars (Y=20) -->
                        <rect x="62.5" y="20" width="25" height="80" fill="#FFF"/> <!-- C -->
                        <rect x="87.5" y="20" width="25" height="80" fill="#1E293B"/> <!-- C# -->
