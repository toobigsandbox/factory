                    </g>

                    <!-- Numbers & Blanks -->
                    <!-- 1 --> <text x="71" y="160" font-family="Inter" font-size="12" font-weight="bold" fill="#854D0E">1</text>
                    <!-- Blank (C#) --> <rect x="87.5" y="140" width="25" height="30" fill="#FDE047"/>
