                    <!-- Grid Lines on Strip matching the 25px bar width -->
                    <g stroke="#CA8A04" stroke-width="1">
                        <line x1="87.5" y1="140" x2="87.5" y2="170"/>
                        <line x1="112.5" y1="140" x2="112.5" y2="170"/>
