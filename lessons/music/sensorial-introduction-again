                        <rect x="337.5" y="50" width="25" height="80" fill="#FFF" stroke="#3B82F6" stroke-width="2"/> <!-- 7: B -->
                        <rect x="362.5" y="50" width="25" height="80" fill="#FFF" stroke="#3B82F6" stroke-width="2"/> <!-- 8: C -->
                    </g>
                    
