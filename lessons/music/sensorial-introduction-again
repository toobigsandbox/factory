                        <rect x="212.5" y="20" width="25" height="80" fill="#1E293B"/> <!-- F# -->
                        <rect x="237.5" y="20" width="25" height="80" fill="#FFF"/> <!-- G -->
                        <rect x="262.5" y="20" width="25" height="80" fill="#1E293B"/> <!-- G# -->
